{
    "name": "DF_RWP_Transform",
    "properties": {
        "description": "Mapping Data Flow: joins, filters, test code mapping, point-in-time price resolution, aggregation. Outputs to ADLS gold zone as Parquet partitioned by year(DateEnter).",
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "name": "SrcResults",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "starlims/RESULTS"
                        }
                    }
                },
                {
                    "name": "SrcCentralReceiving",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "starlims/CENTRALRECEIVING"
                        }
                    }
                },
                {
                    "name": "SrcRasClients",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "starlims/RASCLIENTS"
                        }
                    }
                },
                {
                    "name": "SrcFolders",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "starlims/FOLDERS"
                        }
                    }
                },
                {
                    "name": "SrcTestGroupNames",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "rwp/TESTGROUPNAMES"
                        }
                    }
                },
                {
                    "name": "SrcTests",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "rwp/TESTS"
                        }
                    }
                },
                {
                    "name": "SrcRasPriceList",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "rwp/RASPRICELIST"
                        }
                    }
                },
                {
                    "name": "SrcRasTestPrices",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "rwp/RASTESTPRICES"
                        }
                    }
                },
                {
                    "name": "SrcMetadataLookup",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "staging",
                            "Directory": "rwp/METADATA_LOOKUP_VALUES"
                        }
                    }
                }
            ],
            "sinks": [
                {
                    "name": "SinkGoldParquet",
                    "dataset": {
                        "referenceName": "DS_ADLS_Parquet",
                        "type": "DatasetReference",
                        "parameters": {
                            "Container": "gold",
                            "Directory": "rwp/fact_results_with_pricing"
                        }
                    }
                }
            ],
            "transformations": [
                {
                    "name": "DedupeResults",
                    "description": "Deduplicate Results (groupBy ORIGREC)"
                },
                {
                    "name": "DedupeFolders",
                    "description": "Deduplicate Folders (groupBy FOLDERNO)"
                },
                {
                    "name": "DedupeCR",
                    "description": "Deduplicate CentralReceiving (groupBy ORIGREC)"
                },
                {
                    "name": "DedupeClients",
                    "description": "Deduplicate RasClients (groupBy RASCLIENTID)"
                },
                {
                    "name": "DedupeTGN",
                    "description": "Deduplicate TestGroupNames (groupBy TESTGROUPNAME)"
                },
                {
                    "name": "DedupeTests",
                    "description": "Deduplicate Tests (groupBy TESTNO)"
                },
                {
                    "name": "DedupePriceList",
                    "description": "Deduplicate RasPriceList (groupBy PRICELISTID, PRICELISTVERSION)"
                },
                {
                    "name": "DedupeTestPrices",
                    "description": "Deduplicate RasTestPrices (groupBy PRICELISTID, PRICELISTVERSION, TESTCODE)"
                },
                {
                    "name": "DedupeMetadata",
                    "description": "Deduplicate MetadataLookup (groupBy LOOKUP_NAME, VALUE)"
                },
                {
                    "name": "FilterResults",
                    "description": "Step 2a: Filter out QNS/C/U results and excluded test codes"
                },
                {
                    "name": "JoinResultsFolders",
                    "description": "Step 2b: Results LEFT JOIN Folders on FOLDERNO"
                },
                {
                    "name": "SelectAfterJoinRF",
                    "description": "Resolve duplicate columns after Results-Folders join"
                },
                {
                    "name": "JoinFoldersCR",
                    "description": "Step 2b: LEFT JOIN CentralReceiving on EXTERNAL_ID"
                },
                {
                    "name": "SelectAfterJoinFCR",
                    "description": "Resolve duplicate columns after Folders-CentralReceiving join"
                },
                {
                    "name": "JoinCRClients",
                    "description": "Step 2b: LEFT JOIN RasClients on RASCLIENTID"
                },
                {
                    "name": "SelectAfterJoinCRC",
                    "description": "Resolve duplicate columns after CentralReceiving-Clients join"
                },
                {
                    "name": "FilterCompanies",
                    "description": "Step 2c: Exclude test companies, zzz%, RESEARCH ONLY, Internal category, COMPNAME containing Internal"
                },
                {
                    "name": "JoinTestGroupNames",
                    "description": "Step 2e: LEFT JOIN TestGroupNames on TESTGROUPNAME"
                },
                {
                    "name": "SelectAfterJoinTGN",
                    "description": "Resolve duplicate columns after TestGroupNames join"
                },
                {
                    "name": "JoinTests",
                    "description": "Step 2e: LEFT JOIN Tests on TESTGROUPNAME = TESTNO"
                },
                {
                    "name": "SelectAfterJoinTests",
                    "description": "Resolve duplicate columns after Tests join"
                },
                {
                    "name": "DeriveTestCodeAndPanel",
                    "description": "Step 2f: Resolve test code via mapping or legacy_testcode. Determine IsPanel flag."
                },
                {
                    "name": "DeriveHasPending",
                    "description": "Step 2d: Flag folders with Logged/Draft results"
                },
                {
                    "name": "DeriveCancelStatus",
                    "description": "Step 2h: CancelStatus = Cancel if S='Cancel' or RN3='C', else ''"
                },
                {
                    "name": "ConditionalSplitPanelVsTest",
                    "description": "Step 2g: Split panel tests vs non-panel for different pricing paths"
                },
                {
                    "name": "FilterReleasedPriceLists",
                    "description": "Step 2g: Filter to STATUS='RELEASED' price lists only (match SP)"
                },
                {
                    "name": "JoinTestPricesWithReleasedPL",
                    "description": "Step 2g: Join RASTESTPRICES with released price lists"
                },
                {
                    "name": "SelectAfterJoinTPR",
                    "description": "Resolve duplicate columns after TestPrices-PriceList join"
                },
                {
                    "name": "JoinNonPanelPrices",
                    "description": "Step 2g: Join non-panel results with released price lookup"
                },
                {
                    "name": "SelectAfterJoinNPP",
                    "description": "Resolve duplicate columns after non-panel prices join"
                },
                {
                    "name": "DeriveNonPanelPrice",
                    "description": "Step 2g: Extract non-panel price fields"
                },
                {
                    "name": "FilterPanelByTestPrice",
                    "description": "Filter panel results to only those with matching released test prices (matches SP WHERE behavior)"
                },
                {
                    "name": "LookupPanelName",
                    "description": "Step 2g: Panel pricing - look up panel name from code via METADATA_LOOKUP_VALUES"
                },
                {
                    "name": "DerivePanelName",
                    "description": "Step 2g: Extract panel name from metadata lookup"
                },
                {
                    "name": "DropMetadataCols",
                    "description": "Drop first metadata join columns to avoid duplicates in self-join"
                },
                {
                    "name": "LookupPanelPrice",
                    "description": "Step 2g: Panel pricing - look up price from panel name via METADATA_LOOKUP_VALUES"
                },
                {
                    "name": "DerivePanelPrice",
                    "description": "Step 2g: Extract panel price fields"
                },
                {
                    "name": "UnionPricingPaths",
                    "description": "Step 2g: Combine test-priced and panel-priced rows"
                },
                {
                    "name": "SelectGoldColumns",
                    "description": "Step 2i: Normalize column names for gold Parquet output (individual result rows)"
                },
                {
                    "name": "AddETLLoadDate",
                    "description": "Add ETL_LoadDate = currentTimestamp()"
                },
                {
                    "name": "DerivePartitionYear",
                    "description": "Derive year and month partition columns from DateEnter for Parquet partitioning"
                },
                {
                    "name": "AggLatestResultByOrdno",
                    "description": "Aggregate max DATEENTER per ORDNO to get LatestResultDate"
                },
                {
                    "name": "JoinLatestResult",
                    "description": "Left join aggregated result with LatestResultDate on ORDNO"
                },
                {
                    "name": "SelectAfterJoinLR",
                    "description": "Resolve duplicate columns after LatestResultDate join"
                }
            ],
            "scriptLines": [
                "// =============================================================================",
                "// DF_RWP_Transform - ADF Mapping Data Flow Script",
                "// =============================================================================",
                "",
                "// --- Step 2a: Filter Results ---",
                "source(output(",
                "    ORIGREC as integer,",
                "    FOLDERNO as string,",
                "    ORDNO as string,",
                "    TESTCODE as integer,",
                "    ANALYTE as string,",
                "    FINAL as string,",
                "    NUMRES as string,",
                "    RN2 as string,",
                "    RN3 as string,",
                "    S as string,",
                "    DATEENTER as timestamp",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcResults",
                "",
                "// --- Step 2d: Flag folders with pending results (BEFORE filtering) ---",
                "// Must run before FilterResults so Logged/Draft rows are still in the data",
                "// The SP checks NOT EXISTS against ALL results in the folder, not just filtered ones",
                "DedupeResults window(",
                "    over(FOLDERNO),",
                "    asc(DATEENTER, true),",
                "    HasPendingResults = iif(sum(iif(in(['Logged','Draft'], S), 1, 0)) > 0, true(), false())",
                ") ~> DeriveHasPending",
                "",
                "DeriveHasPending filter(",
                "    !in(['QNS','C','U'], NUMRES)",
                "    && S != 'Cancel'",
                "    && !in([432,429,443,440], TESTCODE)",
                ") ~> FilterResults",
                "",
                "// --- Sources (other tables) ---",
                "source(output(",
                "    ORIGREC as integer,",
                "    EXTERNAL_ID as string,",
                "    BIRTH_DATE as timestamp,",
                "    CLIENT_SAMPLE_ID as string,",
                "    DATE_COLLECTED as timestamp,",
                "    FIRST_NAME as string,",
                "    LAST_NAME as string,",
                "    SPEC_SOURCE as string,",
                "    RASCLIENTID as string",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcCentralReceiving",
                "",
                "source(output(",
                "    RASCLIENTID as string,",
                "    COMPNAME as string,",
                "    CATEGORY as string,",
                "    STATE as string,",
                "    CITY as string,",
                "    ZIP as string,",
                "    PRICELISTID as string",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcRasClients",
                "",
                "source(output(",
                "    FOLDERNO as string,",
                "    EXTERNAL_ID as string,",
                "    TESTGROUPNAME as string",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcFolders",
                "",
                "source(output(",
                "    TESTGROUPNAME as string,",
                "    TESTPANEL as string",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcTestGroupNames",
                "",
                "source(output(",
                "    TESTNO as string,",
                "    TESTCODE as string,",
                "    LEGACY_TESTCODE as string",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcTests",
                "",
                "source(output(",
                "    PRICELISTID as string,",
                "    PRICELISTVERSION as integer,",
                "    STARTDDATE as timestamp,",
                "    STATUS as string,",
                "    EXPDATE as timestamp",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcRasPriceList",
                "",
                "source(output(",
                "    PRICELISTID as string,",
                "    PRICELISTVERSION as integer,",
                "    TESTCODE as integer,",
                "    PRICE as decimal(8,2)",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcRasTestPrices",
                "",
                "source(output(",
                "    LOOKUP_NAME as string,",
                "    VALUE as string,",
                "    TEXT as string",
                "),",
                "    allowSchemaDrift: true,",
                "    validateSchema: false",
                ") ~> SrcMetadataLookup",
                "",
                "// --- Deduplicate sources (staging has ~55 duplicate extract loads) ---",
                "SrcResults aggregate(groupBy(ORIGREC),",
                "    FOLDERNO = first(FOLDERNO),",
                "    ORDNO = first(ORDNO),",
                "    TESTCODE = first(TESTCODE),",
                "    ANALYTE = first(ANALYTE),",
                "    FINAL = first(FINAL),",
                "    NUMRES = first(NUMRES),",
                "    RN2 = first(RN2),",
                "    RN3 = first(RN3),",
                "    S = first(S),",
                "    DATEENTER = first(DATEENTER)",
                ") ~> DedupeResults",
                "",
                "SrcFolders aggregate(groupBy(FOLDERNO),",
                "    EXTERNAL_ID = first(EXTERNAL_ID),",
                "    TESTGROUPNAME = first(TESTGROUPNAME)",
                ") ~> DedupeFolders",
                "",
                "SrcCentralReceiving aggregate(groupBy(ORIGREC),",
                "    EXTERNAL_ID = first(EXTERNAL_ID),",
                "    BIRTH_DATE = first(BIRTH_DATE),",
                "    CLIENT_SAMPLE_ID = first(CLIENT_SAMPLE_ID),",
                "    DATE_COLLECTED = first(DATE_COLLECTED),",
                "    FIRST_NAME = first(FIRST_NAME),",
                "    LAST_NAME = first(LAST_NAME),",
                "    SPEC_SOURCE = first(SPEC_SOURCE),",
                "    RASCLIENTID = first(RASCLIENTID)",
                ") ~> DedupeCR",
                "",
                "SrcRasClients aggregate(groupBy(RASCLIENTID),",
                "    COMPNAME = first(COMPNAME),",
                "    CATEGORY = first(CATEGORY),",
                "    STATE = first(STATE),",
                "    CITY = first(CITY),",
                "    ZIP = first(ZIP),",
                "    PRICELISTID = first(PRICELISTID)",
                ") ~> DedupeClients",
                "",
                "SrcTestGroupNames aggregate(groupBy(TESTGROUPNAME),",
                "    TESTPANEL = first(TESTPANEL)",
                ") ~> DedupeTGN",
                "",
                "SrcTests aggregate(groupBy(TESTNO),",
                "    TESTCODE = first(TESTCODE),",
                "    LEGACY_TESTCODE = first(LEGACY_TESTCODE)",
                ") ~> DedupeTests",
                "",
                "SrcRasPriceList aggregate(groupBy(PRICELISTID, PRICELISTVERSION),",
                "    STARTDDATE = first(STARTDDATE),",
                "    STATUS = first(STATUS),",
                "    EXPDATE = first(EXPDATE)",
                ") ~> DedupePriceList",
                "",
                "SrcRasTestPrices aggregate(groupBy(PRICELISTID, PRICELISTVERSION, TESTCODE),",
                "    PRICE = first(PRICE)",
                ") ~> DedupeTestPrices",
                "",
                "SrcMetadataLookup aggregate(groupBy(LOOKUP_NAME, VALUE),",
                "    TEXT = first(TEXT)",
                ") ~> DedupeMetadata",
                "",
                "// --- Step 2b: Join chain ---",
                "FilterResults, DedupeFolders join(",
                "    FilterResults@FOLDERNO == DedupeFolders@FOLDERNO,",
                "    joinType: 'left',",
                "    matchType: 'exact'",
                ") ~> JoinResultsFolders",
                "",
                "JoinResultsFolders select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinRF",
                "",
                "SelectAfterJoinRF, DedupeCR join(",
                "    SelectAfterJoinRF@EXTERNAL_ID == DedupeCR@EXTERNAL_ID,",
                "    joinType: 'left',",
                "    matchType: 'exact'",
                ") ~> JoinFoldersCR",
                "",
                "JoinFoldersCR select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinFCR",
                "",
                "SelectAfterJoinFCR, DedupeClients join(",
                "    SelectAfterJoinFCR@RASCLIENTID == DedupeClients@RASCLIENTID,",
                "    joinType: 'left',",
                "    matchType: 'exact'",
                ") ~> JoinCRClients",
                "",
                "JoinCRClients select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinCRC",
                "",
                "// --- Step 2c: Filter companies ---",
                "SelectAfterJoinCRC filter(",
                "    !startsWith(upper(COMPNAME), 'ZZZ')",
                "    && !in(['Test RightFax 2','Test RightFax 1','Test RightFax 4','ACCL0933','RESEARCH ONLY','MiraVista Quality System','Greater Than','Additional Positive Unconfirmed'], COMPNAME)",
                "    && !startsWith(COMPNAME, 'RESEARCH ONLY')",
                "    && !contains(COMPNAME, 'Internal')",
                "    && CATEGORY != 'Internal'",
                ") ~> FilterCompanies",
                "",
                "// --- Step 2e: Join test group names and tests ---",
                "FilterCompanies, DedupeTGN join(",
                "    FilterCompanies@TESTGROUPNAME == DedupeTGN@TESTGROUPNAME,",
                "    joinType: 'left',",
                "    matchType: 'exact'",
                ") ~> JoinTestGroupNames",
                "",
                "JoinTestGroupNames select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinTGN",
                "",
                "SelectAfterJoinTGN, DedupeTests join(",
                "    TESTGROUPNAME == DedupeTests@TESTNO,",
                "    joinType: 'left',",
                "    matchType: 'exact'",
                ") ~> JoinTests",
                "",
                "JoinTests select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinTests",
                "",
                "// --- Step 2f: Derive test code resolution and panel flag ---",
                "SelectAfterJoinTests derive(",
                "    IsPanel = iif(like(TESTGROUPNAME, '%panel%'), true(), iif(TESTPANEL == 'Y', true(), false())),",
                "    SourceTestCode = TESTCODE,",
                "    ResolvedTestCode = iif(",
                "        !isNull(TESTNO) && LEGACY_TESTCODE != '',",
                "        toInteger(LEGACY_TESTCODE),",
                "        case(TESTCODE == 318, 316,",
                "            TESTCODE == 457, 331,",
                "            TESTCODE == 465, 402,",
                "            TESTCODE == 459, 332,",
                "            TESTCODE == 460, 315,",
                "            TESTCODE == 461, 316,",
                "            TESTCODE == 462, 320,",
                "            TESTCODE == 463, 321,",
                "            TESTCODE == 467, 403,",
                "            TESTCODE == 469, 404,",
                "            TESTCODE == 466, 405,",
                "            TESTCODE == 468, 406,",
                "            TESTCODE",
                "        )",
                "    )",
                ") ~> DeriveTestCodeAndPanel",
                "",
                "// --- Step 2h: Derive cancel status ---",
                "DeriveTestCodeAndPanel derive(",
                "    CancelStatus = iif(S == 'Cancel', 'Cancel', iif(RN3 == 'C', 'Cancel', ''))",
                ") ~> DeriveCancelStatus",
                "",
                "// --- Step 2g: Point-in-time pricing (THE CRITICAL FIX) ---",
                "// Conditional split: panel vs non-panel",
                "DeriveCancelStatus split(",
                "    IsPanel == true(),",
                "    disjoint: true",
                ") ~> ConditionalSplitPanelVsTest@(PanelTests, NonPanelTests)",
                "",
                "// --- Non-panel pricing path ---",
                "// Point-in-time: join test prices with ALL pricelist versions (not just Released)",
                "// then match to orders where STARTDDATE <= DATEENTER < EXPDATE",
                "DedupeTestPrices, DedupePriceList join(",
                "    DedupeTestPrices@PRICELISTID == DedupePriceList@PRICELISTID",
                "    && DedupeTestPrices@PRICELISTVERSION == DedupePriceList@PRICELISTVERSION,",
                "    joinType: 'inner',",
                "    matchType: 'exact'",
                ") ~> JoinTestPricesWithAllPL",
                "",
                "JoinTestPricesWithAllPL select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinTPR",
                "",
                "// Join non-panel results with price lookup: PRICELISTID + TESTCODE + date range",
                "ConditionalSplitPanelVsTest@NonPanelTests, SelectAfterJoinTPR join(",
                "    PRICELISTID == SelectAfterJoinTPR@PRICELISTID",
                "    && SourceTestCode == SelectAfterJoinTPR@TESTCODE",
                "    && SelectAfterJoinTPR@STARTDDATE <= DATEENTER",
                "    && SelectAfterJoinTPR@EXPDATE > DATEENTER,",
                "    joinType: 'left',",
                "    broadcast: 'right'",
                ") ~> JoinNonPanelPrices",
                "",
                "JoinNonPanelPrices select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinNPP",
                "",
                "// Rank by STARTDDATE desc per order+test to pick most recent active version",
                "SelectAfterJoinNPP window(",
                "    over(ORDNO, SourceTestCode, ANALYTE),",
                "    desc(STARTDDATE, true),",
                "    PriceRank = rowNumber()",
                ") ~> RankNonPanelPrices",
                "",
                "// Keep only the top-ranked price (or rows with no price match)",
                "RankNonPanelPrices filter(",
                "    PriceRank == 1 || isNull(PRICE)",
                ") ~> FilterTopPrice",
                "",
                "FilterTopPrice derive(",
                "    Price = PRICE,",
                "    PriceListVersion = PRICELISTVERSION,",
                "    PricingMethod = 'TEST'",
                ") ~> DeriveNonPanelPrice",
                "// Filter panel results: only keep analytes that have matching test prices in any version",
                "ConditionalSplitPanelVsTest@PanelTests, SelectAfterJoinTPR exists(",
                "    PRICELISTID == SelectAfterJoinTPR@PRICELISTID",
                "    && SourceTestCode == SelectAfterJoinTPR@TESTCODE,",
                "    negate: false",
                ") ~> FilterPanelByTestPrice",
                "",
                "",
                "// --- Panel pricing path ---",
                "// Step 1: Look up panel name from code",
                "FilterPanelByTestPrice, DedupeMetadata join(",
                "    toString(SourceTestCode) == DedupeMetadata@VALUE",
                "    && DedupeMetadata@LOOKUP_NAME == 'PanelPricing',",
                "    joinType: 'left',",
                "    broadcast: 'right'",
                ") ~> LookupPanelName",
                "",
                "// Step 2: Look up price from panel name",
                "LookupPanelName derive(",
                "    PanelName = DedupeMetadata@TEXT",
                ") ~> DerivePanelName",
                "",
                "// Drop first metadata join columns to avoid duplicates in self-join",
                "DerivePanelName select(mapColumn(",
                "    each(match(name != 'LOOKUP_NAME' && name != 'VALUE' && name != 'TEXT'))",
                ")) ~> DropMetadataCols",
                "",
                "// Self-join metadata to get price by panel name",
                "DropMetadataCols, DedupeMetadata join(",
                "    PanelName == DedupeMetadata@VALUE",
                "    && DedupeMetadata@LOOKUP_NAME == 'PanelPricing',",
                "    joinType: 'left',",
                "    broadcast: 'right'",
                ") ~> LookupPanelPrice",
                "",
                "LookupPanelPrice derive(",
                "    Price = toDecimal(DedupeMetadata@TEXT, 8, 2),",
                "    PriceListVersion = toInteger(null()),",
                "    PricingMethod = 'PANEL'",
                ") ~> DerivePanelPrice",
                "",
                "// --- Union panel + non-panel ---",
                "DeriveNonPanelPrice, DerivePanelPrice union(byName: true) ~> UnionPricingPaths",
                "",
                "// --- Step 2i: Normalize column names for gold output (individual result rows) ---",
                "// Aggregation moved to Synapse query layer so date filtering happens BEFORE GROUP BY",
                "UnionPricingPaths select(mapColumn(",
                "    ORDNO,",
                "    COMPNAME,",
                "    ExternalId = EXTERNAL_ID,",
                "    BirthDate = BIRTH_DATE,",
                "    ClientSampleId = CLIENT_SAMPLE_ID,",
                "    FirstName = FIRST_NAME,",
                "    LastName = LAST_NAME,",
                "    DateCollected = DATE_COLLECTED,",
                "    SpecSource = SPEC_SOURCE,",
                "    DateEnter = DATEENTER,",
                "    SourceTestCode,",
                "    ResolvedTestCode,",
                "    TestGroupName = TESTGROUPNAME,",
                "    IsPanel,",
                "    Analyte = ANALYTE,",
                "    Final = FINAL,",
                "    NumRes = NUMRES,",
                "    RN2,",
                "    CancelStatus,",
                "    HasPendingResults,",
                "    Price,",
                "    PriceListId = PRICELISTID,",
                "    PriceListVersion,",
                "    PricingMethod,",
                "    Category = CATEGORY,",
                "    State = STATE,",
                "    City = CITY,",
                "    Zip = ZIP",
                ")) ~> SelectGoldColumns",
                "",
                "// --- Aggregate latest result date per ORDNO ---",
                "DedupeResults aggregate(groupBy(ORDNO),",
                "    LatestResultDate = max(DATEENTER)",
                ") ~> AggLatestResultByOrdno",
                "",
                "SelectGoldColumns, AggLatestResultByOrdno join(",
                "    SelectGoldColumns@ORDNO == AggLatestResultByOrdno@ORDNO,",
                "    joinType: 'left',",
                "    matchType: 'exact'",
                ") ~> JoinLatestResult",
                "",
                "JoinLatestResult select(mapColumn(",
                "    each(match(true()))",
                "),",
                "    skipDuplicateMapInputs: true,",
                "    skipDuplicateMapOutputs: true",
                ") ~> SelectAfterJoinLR",
                "",
                "// --- Add ETL metadata ---",
                "SelectAfterJoinLR derive(",
                "    ETL_LoadDate = currentTimestamp()",
                ") ~> AddETLLoadDate",
                "",
                "// --- Derive partition year and month ---",
                "AddETLLoadDate derive(",
                "    year = year(DateEnter),",
                "    month = month(DateEnter)",
                ") ~> DerivePartitionYear",
                "",
                "// --- Sink to gold zone ---",
                "// Partitions by year(DateEnter)/month(DateEnter). The master pipeline",
                "// deletes the target year=YYYY/ folders before this runs, so we get a",
                "// clean overwrite of just the rolling window partitions.",
                "DerivePartitionYear sink(",
                "    allowSchemaDrift: true,",
                "    validateSchema: false,",
                "    format: 'parquet',",
                "    partitionBy('key', 0, year, month),",
                "    umask: 0022,",
                "    truncate: false,",
                "    fileSystem: 'gold',",
                "    folderPath: 'rwp/fact_results_with_pricing'",
                ") ~> SinkGoldParquet"
            ]
        }
    }
}