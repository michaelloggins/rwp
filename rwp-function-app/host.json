{
    "version": "2.0",
    "logging": {
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            }
        },
        "logLevel": {
            "default": "Information",
            "Host.Results": "Error",
            "Function": "Information",
            "rwp": "Information"
        }
    },
    "extensions": {
        "http": {
            "routePrefix": "",
            "maxOutstandingRequests": 100,
            "maxConcurrentRequests": 50,
            "dynamicThrottlesEnabled": false
        }
    },
    "Host": {
        "CORS": {
            "AllowedOrigins": [
                "https://func-rwp-cus-001.azurewebsites.net",
                "https://localhost:3000"
            ],
            "SupportCredentials": true
        }
    },
    "functionTimeout": "00:05:00"
}
